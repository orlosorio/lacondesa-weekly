# Copy to `.env.local` — never commit real secrets.

# Sanity (public — safe for browser / Studio)
NEXT_PUBLIC_SANITY_PROJECT_ID="your_project_id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-01-01"

# Optional: read token for draft/private APIs
SANITY_API_READ_TOKEN=""

# Wall of Love + CMS writes (API routes: vote, submit-restaurant). Never expose to the client.
# Also accepted as SANITY_WRITE_TOKEN (same value).
SANITY_API_WRITE_TOKEN=""

# Revalidation webhook (generate a random string; use same value in Sanity webhook URL query)
REVALIDATE_SECRET=""

# Legacy aliases (if your tooling still expects these — mirror the NEXT_PUBLIC_* values)
SANITY_PROJECT_ID=""
SANITY_DATASET=""
SANITY_API_TOKEN=""
